# WordPress core (installed from the official Docker image — not versioned)
/*
!.gitignore
!LICENSE
!README.md
!docker-compose.yml
!install.sh
!create-plugin.sh
!.env.sample
!Dockerfile
!Makefile
!docker/
!wp-content/

# wp-content: only mu-plugins, plugins, themes, upgrade (empty dir for installs)
wp-content/*
!wp-content/mu-plugins/
!wp-content/upgrade/
wp-content/upgrade/*
!wp-content/upgrade/.gitkeep
wp-content/plugins/*
!wp-content/themes/

# ignore these plugins
wp-content/plugins/hello.php
wp-content/plugins/example-plugin/

# ignore default themes shipped with WordPress
wp-content/themes/twenty*/

# ignore node dependency directories
node_modules/

# ignore log files and databases
*.log
*.sql
*.sqlite

# ignore .env
.env

# database dumps
backups/
